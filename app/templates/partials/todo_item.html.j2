<li
  class="border border-zinc-800 bg-zinc-900/50 rounded-xl p-4 flex items-center"
  id="todo-{{ todo.id }}"
>
  <button
    class="rounded-full border-2 border-zinc-500 size-5 hover:border-cyan-400"
  ></button>
  <span class="ml-4 grow">{{ todo.title }}</span>
  <button
    hx-delete="/todos/{{ todo.id }}"
    hx-target="#todo-{{ todo.id }}"
    hx-swap="outerHTML"
  >
    <svg
      xmlns="http://www.w3.org/2000/svg"
      width="24"
      height="24"
      viewBox="0 0 24 24"
      fill="none"
      stroke="currentColor"
      stroke-width="2"
      stroke-linecap="round"
      stroke-linejoin="round"
      class="size-5 text-zinc-600 hover:text-red-400"
    >
      <path d="M18 6 6 18" />
      <path d="m6 6 12 12" />
    </svg>
  </button>
</li>
